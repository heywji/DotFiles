[copr:copr.fedorainfracloud.org:group_osci:mini-tps]
name=Copr repo for mini-tps owned by @osci
baseurl=https://download.copr.fedorainfracloud.org/results/@osci/mini-tps/fedora-$releasever-$basearch/
type=rpm-md
skip_if_unavailable=True
gpgcheck=1
gpgkey=https://download.copr.fedorainfracloud.org/results/@osci/mini-tps/pubkey.gpg
repo_gpgcheck=0
enabled=1
enabled_metadata=1
